DATABASE_URL="postgresql://inbox:inbox@localhost:5432/inbox"
NUXT_SESSION_PASSWORD="change-me-to-a-long-random-string-at-least-32-chars"

# Public site URL (password reset, booking confirmation links)
# NUXT_PUBLIC_SITE_URL=https://your-domain.com

# PWA — disabled by default until explicitly enabled (prevents stale SW cache issues)
# NUXT_PUBLIC_ENABLE_PWA=true

# Behnaz pilot — hide coach discovery/register UX (club + athlete + admin only).
# Coach data model and role-gated APIs remain; public coach CTAs/routes are off.
# NUXT_PUBLIC_PILOT_NO_COACH=true
# PILOT_NO_COACH=true

# Production deploy (scripts/start-production.mjs)
# SEED_ON_EMPTY=true          — seed only when database has zero users (remove after first deploy)
# SEED_DEMO_DATA=true         — create demo clubs/coaches/accounts (local dev only; never in production)
# FORCE_SEED_RESET=true       — wipe all data before seeding (dev only; never in production)

# Error tracking (optional — set on Liara for production monitoring)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# GIT_COMMIT_SHA=optional-release-tag

# Admin club provisioning
# ADMIN_PROVISION_SECRET=your-long-random-secret

# Payments mode: pay_at_club (default), test, or live
# PAYMENTS_MODE=pay_at_club
# PAYMENT_PROVIDER=zarinpal
# ZARINPAL_MERCHANT_ID=your-merchant-id

# SMS — keep SMS_PROVIDER=log for pilot/local until the final SMS cutover prompt.
# OTP returns debugCode while provider resolves to log (or after a non-prod live send failure).
# For live Kavenegar: SMS_ENABLED=true, SMS_PROVIDER=live, and KAVENEGAR_API_KEY.
# SMS_ENABLED=false
# SMS_PROVIDER=log
# SMS_PROVIDER=live
# KAVENEGAR_API_KEY=your-kavenegar-api-key
# Optional: panel-approved Verify Lookup template (e.g. inbox-verify with %token%). Falls back to sms/send without it.
# KAVENEGAR_TEMPLATE=inbox-verify

# Rate limiting — optional Redis for multi-instance deploys
# REDIS_URL=redis://localhost:6379

# Email (SMTP) — set EMAIL_ENABLED=true to send real emails
# EMAIL_ENABLED=false
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="inbox <noreply@yourdomain.com>"

# Object storage (S3-compatible — e.g. Liara bucket or other provider)
# S3_ENDPOINT=https://storage.example.com
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_PUBLIC_URL=https://your-bucket-public-url

# Google OAuth (optional — fail-closed when unset; button hidden, /auth/google → /login?error=google)
# Local: create an OAuth 2.0 Web client in Google Cloud Console, then set:
#   NUXT_OAUTH_GOOGLE_CLIENT_ID=....apps.googleusercontent.com
#   NUXT_OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-...
#   NUXT_OAUTH_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google
#   NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Prod example redirect: https://inboxs.ir/auth/google
# NUXT_OAUTH_GOOGLE_CLIENT_ID=
# NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
# NUXT_OAUTH_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google
