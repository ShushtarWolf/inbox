DATABASE_URL="postgresql://inbox:inbox@localhost:5432/inbox"
NUXT_SESSION_PASSWORD="change-me-to-a-long-random-string-at-least-32-chars"

# Public site URL (password reset, booking confirmation links)
# NUXT_PUBLIC_SITE_URL=https://your-domain.com

# Public contact details (Enamad /contact page). Defaults: mobile 09124777927, info@inboxs.ir
# NUXT_PUBLIC_CONTACT_OWNER_NAME=نام شما
# NUXT_PUBLIC_CONTACT_ADDRESS=تهران، …
# NUXT_PUBLIC_CONTACT_POSTAL_CODE=##########
# NUXT_PUBLIC_CONTACT_LANDLINE=021-…
# NUXT_PUBLIC_CONTACT_MOBILE=09124777927
# NUXT_PUBLIC_CONTACT_EMAIL=info@inboxs.ir

# Enamad verification + badge (set after enamad.ir signup — see docs/ENAMAD.md)
# NUXT_PUBLIC_ENAMAD_META_CONTENT=…
# NUXT_PUBLIC_ENAMAD_VERIFY_FILE=1234567.txt
# NUXT_PUBLIC_ENAMAD_TITLE_OVERRIDE=…   # temporary; remove after verify
# NUXT_PUBLIC_ENAMAD_ID=…
# NUXT_PUBLIC_ENAMAD_CODE=…

# PWA — disabled by default until explicitly enabled (prevents stale SW cache issues)
# NUXT_PUBLIC_ENABLE_PWA=true

# Behnaz pilot — hide coach discovery/register UX (club + athlete + admin only).
# Prefer PILOT_NO_COACH for server APIs/sitemap (no rebuild). Public flag for client nav/redirects.
# Coach data model remains; public coach CTAs/routes stay off when either flag is true.
# PILOT_NO_COACH=true
# NUXT_PUBLIC_PILOT_NO_COACH=true

# Production deploy (scripts/start-production.mjs)
# SEED_ON_EMPTY=true          — seed only when database has zero users (remove after first deploy)
# SEED_DEMO_DATA=true         — create demo clubs/coaches/accounts (local dev only; never in production)
# FORCE_SEED_RESET=true       — wipe all data before seeding (dev only; never in production)

# Error tracking (optional — set on Liara for production monitoring)
# See docs/OPERATIONS.md → "Sentry (error tracking)". Never commit a real DSN.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# GIT_COMMIT_SHA=optional-release-tag
# Local checks (never prints DSN value):
#   npm run sentry:status
# Server test capture (needs ADMIN_PROVISION_SECRET):
#   curl -X POST -H "x-admin-secret: $ADMIN_PROVISION_SECRET" http://localhost:3000/api/admin/sentry-test
# Admin UI: http://localhost:3000/admin/sentry
# Status (needs ADMIN_PROVISION_SECRET):
#   curl -H "x-admin-secret: $ADMIN_PROVISION_SECRET" http://localhost:3000/api/admin/sentry-status

# Admin club provisioning
# ADMIN_PROVISION_SECRET=your-long-random-secret

# Payments mode: pay_at_club (desk-only), test (local — recommended), or live (Zarinpal)
# Local without secrets → simulated gateway at /payments/test-gateway
# PAYMENTS_MODE=test
# PAYMENT_PROVIDER=zarinpal
# Optional sandbox/live merchant (never commit real values):
# ZARINPAL_MERCHANT_ID=
# ZARINPAL_ACCESS_TOKEN=   # live gateway refunds; else cancel credits wallet
# Callback (auto from NUXT_PUBLIC_SITE_URL): {SITE}/payments/callback/zarinpal
# See docs/PAYMENTS.md — do not set PAYMENTS_MODE=live until keys verified.
# SMS — default is safe log/dry-run (no credentials required; OTP returns debugCode).
# Live Kavenegar (OTP + owner CRM + desk guest SMS): set all three:
#   SMS_ENABLED=true
#   SMS_PROVIDER=kavenegar
#   KAVENEGAR_API_KEY=your-kavenegar-api-key
# SMS_PROVIDER=live is also accepted as Kavenegar.
# OTP strongly recommended: panel-approved Verify Lookup template (e.g. inbox-verify with %token%).
# Without it, OTP falls back to sms/send and needs a valid sender line.
#   KAVENEGAR_TEMPLATE=inbox-verify
# Required for free-text sms/send (CRM + booking notify + OTP without template).
# Must match an approved line in the Kavenegar panel — invalid/missing → "ارسال کننده نامعتبر است".
#   KAVENEGAR_SENDER=1000xxxx
# Optional OTP per-phone rate limits (defaults: 3 sends / 10 min, 10 verifies / 10 min):
#   OTP_PHONE_SEND_MAX=3
#   OTP_PHONE_SEND_WINDOW_MS=600000
#   OTP_PHONE_VERIFY_MAX=10
#   OTP_PHONE_VERIFY_WINDOW_MS=600000
# SMS_ENABLED=false
# SMS_PROVIDER=log
# SMS_PROVIDER=live
# KAVENEGAR_API_KEY=your-kavenegar-api-key
# KAVENEGAR_TEMPLATE=inbox-verify
# KAVENEGAR_SENDER=
# Local checks (no secrets printed):
#   npm run sms:status
# Owner CRM reads the same mode from GET /api/owner/sms-status (session auth).
# Admin UI: http://localhost:3000/admin/sms (enter ADMIN_PROVISION_SECRET)
# Admin SMS status (needs ADMIN_PROVISION_SECRET):
#   curl -H "x-admin-secret: $ADMIN_PROVISION_SECRET" http://localhost:3000/api/admin/sms-status
# Process due scheduled CRM campaigns (needs ADMIN_PROVISION_SECRET):
#   curl -X POST -H "x-admin-secret: $ADMIN_PROVISION_SECRET" http://localhost:3000/api/admin/sms/process-scheduled
# Optional later: Liara cron → same POST endpoint (no in-app worker).
# Do not set live credentials on Liara until you intentionally cut over.
# Full go-live checklist: docs/OPERATIONS.md → "SMS auth (Kavenegar OTP)".

# Rate limiting — optional Redis for multi-instance deploys
# REDIS_URL=redis://localhost:6379

# Email (SMTP) — log-by-default; set EMAIL_ENABLED=true + SMTP_HOST to send live
# Unset/false: password reset + booking emails succeed and log only (no SMTP needed for local/CI)
# EMAIL_ENABLED=false
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="inbox <noreply@yourdomain.com>"
# Check: npm run email:status

# Object storage (S3-compatible — Liara Object Storage for prod)
# When all five are unset, uploads go to local public/uploads (localhost).
# See docs/OPERATIONS.md → "Object storage (S3 / Liara)". Never commit real keys.
# Liara dashboard → Object Storage → create bucket (public) → create access key
#   S3_ENDPOINT=https://storage.iran.liara.space
#   S3_BUCKET=your-bucket-name
#   S3_ACCESS_KEY=your-access-key
#   S3_SECRET_KEY=your-secret-key
#   S3_PUBLIC_URL=https://your-bucket-name.storage.iran.liara.space
# Optional: S3_REGION=us-east-1  (default; Liara accepts this)
# Local checks (never prints access/secret keys):
#   npm run storage:status
# Admin status (needs ADMIN_PROVISION_SECRET):
#   curl -H "x-admin-secret: $ADMIN_PROVISION_SECRET" http://localhost:3000/api/admin/storage-status

# Google OAuth (optional — fail-closed when unset: button hidden, /auth/google → /login?error=google)
# See docs/OPERATIONS.md → "Google OAuth (sign-in)" for Console steps.
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID → Web application
#   Authorized JavaScript origins:
#     http://localhost:3000
#     https://inboxs.ir
#   Authorized redirect URIs:
#     http://localhost:3000/auth/google
#     https://inboxs.ir/auth/google
# Required when enabling: CLIENT_ID + CLIENT_SECRET + (REDIRECT_URL or SITE_URL).
# Local:
# NUXT_PUBLIC_SITE_URL=http://localhost:3000
# NUXT_OAUTH_GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# NUXT_OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-...
# NUXT_OAUTH_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google
# Prod (set on Liara; never commit real secrets):
# NUXT_PUBLIC_SITE_URL=https://inboxs.ir
# NUXT_OAUTH_GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# NUXT_OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-...
# NUXT_OAUTH_GOOGLE_REDIRECT_URL=https://inboxs.ir/auth/google
